# Discord Bot Token
DISCORD_TOKEN=Your_Discord_Bot_Token_Here

# Notion API Key
NOTION_API_KEY=Your_Notion_API_Key_Here

# Notion Database ID
NOTION_DATABASE_ID=Your_Notion_Database_ID_Here

# Optional: Notion timezone used when sending start/end times (default: Asia/Bangkok)
# NOTION_TIMEZONE=Asia/Bangkok

# Discord Channel ID (where to send notifications)
DISCORD_CHANNEL_ID=Your_Discord_Channel_ID_Here

# Optional: Multiple Discord Channel IDs (comma-separated)
# If not set, channels can be derived from DISCORD_CHANNEL_DEPARTMENT_FILTERS
# DISCORD_CHANNEL_IDS=123456789012345678,234567890123456789

# Polling interval in seconds (1 minute = 60)
# Minimum allowed by config is 15, max is 3600
POLL_INTERVAL=60

# Optional: role names allowed to run task write commands (/task create/update/move/delete)
# Comma-separated role names. Admins are always allowed.
# TASK_COMMAND_ROLE_NAMES=SMO 69

# Optional: Track only these Department values (comma-separated)
# Leave empty to include all departments by default
# TRACKED_DEPARTMENT=ฝ่ายประธาน,ฝ่ายประสาน

# Optional: Per-channel department filters.
# Format: channelId:Dept1|Dept2,anotherChannelId:Dept3
# Use '*' or 'all' for a channel to receive all departments.
# Channel IDs used here are enough; DISCORD_CHANNEL_IDS can be omitted.
# DISCORD_CHANNEL_DEPARTMENT_FILTERS=1339363141720477791:ฝ่ายประธาน|ฝ่ายประสาน,123456789012345678:ฝ่ายกิจกรรม
