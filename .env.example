# Discord Bot Token
DISCORD_TOKEN=Your_Discord_Bot_Token_Here

# Notion API Key
NOTION_API_KEY=Your_Notion_API_Key_Here

# Notion Database ID
NOTION_DATABASE_ID=Your_Notion_Database_ID_Here

# Discord Channel ID (where to send notifications)
DISCORD_CHANNEL_ID=Your_Discord_Channel_ID_Here

# Optional: Multiple Discord Channel IDs (comma-separated)
# If set, this takes priority over DISCORD_CHANNEL_ID
# DISCORD_CHANNEL_IDS=123456789012345678,234567890123456789

# Polling interval in seconds (1 minute = 60)
# Minimum allowed by config is 15, max is 3600
POLL_INTERVAL=60

# Track only this Notion Organization value
TRACKED_ORGANIZATION=SMO CAMT
